#############################
# OpenTelemetry / New Relic #
#############################

# New Relic ingest endpoint (see "New Relic OTLP endpoint" docs)
# US region default:
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.nr-data.net
# EU example:
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.eu01.nr-data.net

# New Relic license key (used as api-key header).
# The OTEL helper will construct OTEL_EXPORTER_OTLP_HEADERS for you.
NEW_RELIC_LICENSE_KEY=YOUR_NEW_RELIC_LICENSE_KEY

# Recommended protocol and compression
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_COMPRESSION=gzip

# Recommended timeouts / batching (optional, tune as needed)
# OTEL_EXPORTER_OTLP_TIMEOUT=10s
# OTEL_BSP_SCHEDULE_DELAY=5000

# Service names are set in code via resource attributes (service.name).
# You generally do not need to set OTEL_SERVICE_NAME or OTEL_EXPORTER_OTLP_HEADERS.
